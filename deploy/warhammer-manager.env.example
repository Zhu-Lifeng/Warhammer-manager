# Copy to /etc/warhammer-manager.env and chmod 600 (owner root:wh40k).
# This file is loaded by both systemd units.

# User data directory — must stay OUTSIDE the repo checkout so git pull never
# touches user armies / models / uploads. Create it once with:
#   sudo mkdir -p /var/lib/warhammer-manager/uploads
#   sudo chown -R wh40k:wh40k /var/lib/warhammer-manager
WH40K_DATA_DIR=/var/lib/warhammer-manager
WH40K_UPLOAD_DIR=/var/lib/warhammer-manager/uploads

# Flask session secret. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WH40K_SECRET_KEY=replace-me-with-64-hex-chars

# GitHub webhook shared secret. Same value goes into the GitHub webhook UI.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WH40K_WEBHOOK_SECRET=replace-me-with-64-hex-chars

# Branch that triggers deploys. Pushes to any other branch are ignored.
WH40K_DEPLOY_BRANCH=main
