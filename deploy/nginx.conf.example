# Example nginx vhost — drop into /etc/nginx/sites-available/warhammer-manager
# and symlink into sites-enabled. TLS termination via certbot is left as a
# follow-up step (`sudo certbot --nginx -d wh40k.example.com`).

server {
    listen 80;
    server_name wh40k.example.com;

    # Main app
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 100M;   # allow multi-image model uploads
    }

    # GitHub webhook — only POSTs to /github-webhook reach the receiver.
    # Leave the path here identical to the URL configured in GitHub.
    location = /github-webhook {
        proxy_pass http://127.0.0.1:9001/github-webhook;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
