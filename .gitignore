# --- User data (must persist across deploys) -------------------------------
# When deployed via the GitHub webhook these are kept in WH40K_DATA_DIR
# (e.g. /var/lib/warhammer-manager) — completely outside this repo.
# Locally during dev they land at the repo root; never commit them.
app.db
app.db-wal
app.db-shm
/data/
/static/uploads/*
!/static/uploads/.gitkeep

# --- Local secrets / env --------------------------------------------------
.env
.env.local
deploy/.env
